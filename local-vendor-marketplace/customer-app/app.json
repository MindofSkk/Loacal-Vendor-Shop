{
  "expo": {
    "name": "LocalShop",
    "slug": "localshop-customer",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "android": {
      "package": "com.localshop.customer",
      "versionCode": 1,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "defaultChannel": "orders"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Location helps the seller deliver faster."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "08280902-ff39-4892-8b95-c2ea3c5500af"
      }
    },
    "owner": "helloskk"
  }
}
