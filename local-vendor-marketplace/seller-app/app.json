{
  "expo": {
    "name": "LocalShop Seller",
    "slug": "localshop-seller",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "android": {
      "package": "com.localshop.seller",
      "versionCode": 1,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_MEDIA_IMAGES"
      ]
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "defaultChannel": "new-orders"
        }
      ],
      "expo-image-picker"
    ],
    "extra": {
      "eas": {
        "projectId": "e80cc5e8-ae42-44d3-97c0-f8c6e79a179f"
      }
    },
    "owner": "helloskk"
  }
}
